# Copy to /etc/wsl.conf inside the Kinoite WSL distro.
# Then: exit ; wsl --shutdown (from Windows) ; wsl -d Kinoite-WS2

[boot]
systemd=true

[user]
# Linux account that should be default on wsl.exe launch
default=CHANGE_ME

# Optional: set appendWindowsPath=false to reduce "Failed to translate" spam from a long Windows PATH
# [interop]
# enabled=true
# appendWindowsPath=false
