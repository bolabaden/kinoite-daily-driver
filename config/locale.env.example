# Copy to repo-root host-local/locale.env (gitignored) and uncomment/edit.
# Apply with: sudo ./scripts/provision-locale.sh
# Or: KINOITE_LOCALE_ENV=/path/to/file sudo ./scripts/provision-locale.sh
#
# Windows parity: map “Region / Time & language” → timezone; “Preferred languages” → LANG + IME stack
# (IBus/Fcitx5 + langpacks are separate — see docs/input-and-ime.md and distrobox for glibc-langpack-*).

#KINOITE_TIMEZONE=America/Chicago
#KINOITE_LANG=en_US.UTF-8
#KINOITE_KEYMAP=us
# Optional: override X11 layout if different from KEYMAP
#KINOITE_X11_LAYOUT=us
