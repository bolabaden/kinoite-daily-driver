# Never commit raw exports with machine-specific paths or secrets
imports/*.json
imports/*.yaml
imports/*winget*
imports/*.txt
!imports/CAPTURE-MANIFEST.txt
imports/*.csv
imports/*.reg

# Local scratch (tar exports, temp; import script mkdirs as needed)
scratch/

# Local scratch
scripts/debug-*.ps1
*.tar
*.tar.gz
*.tmp
.env
.env.*
!.env.example

# OS
Thumbs.db
Desktop.ini

# Optional gitleaks / tooling
.gitleaks-cache/
.history/

# Python / uv (kinoite-bootstrap-init)
.venv/
__pycache__/
*.py[cod]

# Agent / web scratch (do not commit)
.firecrawl/
.cursor/
research/

# Provisional host secrets + machine-local NM profiles (never commit)
host-local/
**/host-local/
*.secrets.env
config/network/*.local.nmconnection
