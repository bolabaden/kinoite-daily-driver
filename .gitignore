# Never commit raw exports with machine-specific paths or secrets
imports/*.json
imports/*.yaml
imports/*winget*
imports/*.txt
!imports/CAPTURE-MANIFEST.txt
!imports/.gitkeep
imports/*.csv
imports/*.reg

# Local scratch
scripts/debug-*.ps1
*.tar
*.tar.gz
*.tmp
.env
.env.*
!.env.example

# OS
Thumbs.db
Desktop.ini

# Optional gitleaks / tooling
.gitleaks-cache/
.history/

# Agent / web scratch (do not commit)
.firecrawl/
.cursor/hooks/state/
research/

# Provisional host secrets + machine-local NM profiles (never commit)
host-local/
**/host-local/
*.secrets.env
config/network/*.local.nmconnection
